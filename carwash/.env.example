# Database Configuration
DB_SERVER=127.0.0.1
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=carwash_db
DB_PORT=3306

# Hubtel SMS API (for SMS notifications) - Simple & Ghana-friendly
# Get your credentials from https://hubtel.com
# 1. Sign up at hubtel.com
# 2. Go to Developer Tools → API Keys
# 3. Copy your Client ID and API Key
HUBTEL_CLIENT_ID=your_client_id
HUBTEL_API_KEY=your_api_key
HUBTEL_SENDER_ID=WashHub

# SMTP Configuration (for Email notifications)
# Example for Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@washhub.com
SMTP_FROM_NAME=WashHub

# Application Configuration
APP_TIMEZONE=Africa/Accra
SUPPORT_WHATSAPP=233509729601

# JWT Secret (for backend API)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
